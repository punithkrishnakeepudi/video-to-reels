# ── ReelForge - Instagram Automation Tool ───────────────────
# Copy this file to .env and fill in your credentials.
# cp .env.example .env

# ── FastAPI ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
SECRET_KEY=generate-a-random-secret-key-here

# ── Database (SQLite is default — no setup needed) ──────
DATABASE_URL=sqlite:///./reelforge.db

# ── Uploads ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500
REEL_DURATION_SECONDS=30

# ── Instagram / Facebook Graph API ──────────────────────
# To get these credentials:
# 1. Go to https://developers.facebook.com/apps/
# 2. Create a new app (Business type)
# 3. Add Instagram Graph API product
# 4. Get App ID and App Secret from Settings > Basic
# 5. In the app dashboard, add Instagram Testers or submit for review
# 6. Your Instagram account must be a Business or Creator account
#    linked to a Facebook Page
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/auth/instagram/callback

# ── AI Caption Generation ───────────────────────────────
# Options: openai, anthropic, ollama, none (uses templates)
CAPTION_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Local Ollama (https://ollama.com/)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Public URL (for Instagram to fetch your videos) ────
# If running locally, Instagram needs to reach your server.
# You can use ngrok or deploy to a public server.
# For local testing, leave as default.
PUBLIC_BASE_URL=http://localhost:8000

# ── CORS ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
